<Window x:Class="hagymix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hagymix"
        mc:Ignorable="d"
        KeyDown="Main_KeyDown"
        Title="Labyrinth" Height="520" Width="980">
    <Grid  >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="1" Grid.Row="0" x:Name="GameInfoText" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>

        <!-- Gameplay -->
        <Grid  Grid.Column="1" Grid.Row="1" x:Name="MazeGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" Visibility="Hidden"></Grid>

        <!-- Menu -->
        <Grid  Grid.Column="1" Grid.Row="1" x:Name="MenuGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="1" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" x:Name="MenuTitle">Menu</Label>

            <Grid Grid.Column="1" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="5*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="5*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Vertical" Margin="0,8,0,8">
                    <Button Content="Pálya betöltése" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="LoadMapClick" x:Name="LoadMapButton"/>
                    <CheckBox Content="Fedett térkép (csak bejárt részek látszanak)" Margin="0,8,0,0" x:Name="FogModeCheckbox"/>
                </StackPanel>
                <Button Grid.Column="3" Content="Szerkesztő" HorizontalAlignment="Stretch" Grid.Row="2" VerticalAlignment="Stretch" Click="EditorClick" x:Name="EditorButton"/>
            </Grid>

        </Grid>

        <!-- Editor -->
        <Grid  Grid.Column="1" Grid.Row="1" x:Name="Editor" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" Visibility="Hidden">

        </Grid>

        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Button Content="Mentés" Margin="4" Click="SaveGameClick" x:Name="SaveGameButton" Padding="10 5 10 5"/>
            <Button Content="Visszatöltés" Margin="4" Click="LoadGameStateClick" x:Name="LoadSaveButton" Padding="10 5 10 5"/>
            <Button Content="Menü" Margin="4" Click="BackToMenuClick" x:Name="BackToMenuButton" Padding="10 5 10 5"/>
            <Button Content="HU" Margin="4" HorizontalAlignment="Center" VerticalAlignment="Bottom" Click="ToggleLangClick" x:Name="LangToggleBTN" Padding="10 5 10 5"/>
        </StackPanel>
    </Grid>
</Window>
